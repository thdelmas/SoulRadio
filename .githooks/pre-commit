#!/usr/bin/env bash
# Versioned pre-commit hook. Activate once with `make hooks-install`
# (which sets `git config core.hooksPath .githooks`).
#
# Bypass with `git commit --no-verify` only for WIP — fix and recommit
# before pushing; CI runs the same checks.

set -euo pipefail

exec ./scripts/code-quality-check.sh
